{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minibo.local/schemas/bootstrap-account.schema.json",
  "title": "Minibo Bootstrap Account",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageKind",
    "packageId",
    "issuedAtUtc",
    "expiresAtUtc",
    "targetInstance",
    "issuer",
    "account",
    "integrity"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "packageKind": {
      "type": "string",
      "enum": [
        "bootstrap",
        "user"
      ]
    },
    "packageId": {
      "type": "string",
      "minLength": 1
    },
    "issuedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "targetInstance": {
      "type": "string",
      "minLength": 1
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "operator"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "username",
        "displayName",
        "passwordHash",
        "mustChangePassword",
        "roles",
        "permissions"
      ],
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "passwordHash": {
          "type": "string",
          "minLength": 1
        },
        "mustChangePassword": {
          "type": "boolean"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "signatureSvg": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payloadSha256",
        "hmacSha256"
      ],
      "properties": {
        "payloadSha256": {
          "type": "string",
          "minLength": 1
        },
        "hmacSha256": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
